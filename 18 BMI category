# Read weight (kg) and height (meters)
weight = float(input())
height = float(input())

# Calculate BMI
bmi = weight / (height * height)

# Determine category
if bmi < 18.5:
    print("Underweight")
elif bmi < 25:
    print("Normal")
elif bmi < 30:
    print("Overweight")
else:
    print("Obese")


